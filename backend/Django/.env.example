# Django settings module to load.
DJANGO_SETTINGS_MODULE=settings.development

# Required in production. Development can use the insecure fallback in base.py.
SECRET_KEY=change-me

# Production should set this to False. development.py forces DEBUG=True.
DEBUG=True

# Comma-separated hostnames. production.py requires this env var.
ALLOWED_HOSTS=localhost,127.0.0.1

# Required by settings/base.py. Supported by django-environ env.db().
# Example PostgreSQL format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://syscare:syscare@localhost:5432/syscare
